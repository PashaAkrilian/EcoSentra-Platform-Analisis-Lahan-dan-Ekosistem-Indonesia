# Google Earth Engine — Service Account
# Email service account GEE (lihat field "client_email" di file JSON key kamu)
GEE_SERVICE_ACCOUNT=

# Path lokal ke file JSON key service account (dipakai saat development lokal).
# Taruh file JSON-nya di dalam folder credentials/ (sudah di-gitignore),
# JANGAN commit file key-nya.
GEE_KEY_PATH=./credentials/gee-service-account.json

# Isi penuh JSON key sebagai satu baris string (dipakai saat deploy ke platform
# tanpa filesystem persisten, mis. Hugging Face Spaces / Railway — isi env var
# ini lewat secret manager platform tsb, JANGAN taruh nilainya di file ini).
GEE_CREDENTIALS_JSON=
